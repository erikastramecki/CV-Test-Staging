# CoinVoyage API key — server-side only. Used by /api/swap and /api/sale
# route handlers in this app. NEVER prefix with NEXT_PUBLIC_; that would
# inline the live key into the browser bundle.
CV_API_KEY=

# WalletConnect Cloud project ID for RainbowKit. Without it, only injected
# wallets (browser extensions) work; WalletConnect-only wallets are disabled.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
